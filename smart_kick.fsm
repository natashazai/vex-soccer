class FindClosestBall(StateNode):
    """
    Visible ball > post_data (obj).
    Remembered ball > post_success.
    Nothing > post_failure.
    """
    def start(self, event=None):
        super().start(event)
        mem = self.parent.field_memory

        visible = [b for b in mem.balls if b["is_visible"]]
        if visible:
            closest = min(visible, key=lambda b: b["distance"] or 9999)
            self.parent.target_ball = closest
            d = closest.get('distance')
            h = closest.get('heading')
            print(f"[FIND] Ball VISIBLE dist={d if d else '?'} heading={h if h else '?'}")
            self.post_data(closest["obj"])
            return

        remembered = [b for b in mem.balls if b.get("x") is not None]
        if remembered:
            closest = max(remembered, key=lambda b: b["last_seen"])
            self.parent.target_ball = closest
            age = time.time() - closest["last_seen"]
            print(f"[FIND] Ball REMEMBERED ({closest['x']:.0f},{closest['y']:.0f}) "
                  f"{age:.1f}s ago")
            self.post_success()
            return

        print("[FIND] No balls at all")
        self.post_failure()


class GoToRememberedBall(StateNode):
    """Drive toward remembered ball position."""
    def start(self, event=None):
        super().start(event)
        target = self.parent.target_ball
        if not target or target.get("x") is None:
            self.post_completion()
            return

        rx = getattr(robot, "x", 0)
        ry = getattr(robot, "y", 0)
        rh = getattr(robot, "heading", 0)

        bx, by = target["x"], target["y"]
        angle = math.degrees(math.atan2(by - ry, bx - rx))
        turn = angle - rh
        while turn > 180:  turn -= 360
        while turn < -180: turn += 360

        dist = math.sqrt((bx - rx)**2 + (by - ry)**2)
        dist = min(dist, 300)
        dist = max(dist, 30)

        self.parent.remembered_turn = turn
        self.parent.remembered_drive = dist
        print(f"[REMEMBER] Turn {turn:.1f} drive {dist:.0f}mm")
        self.post_data(turn)


class GetBallDistance(StateNode):
    """Stop 40mm short of ball."""
    def start(self, event=None):
        super().start(event)
        target = self.parent.target_ball
        if target and target.get("distance"):
            dist = max(target["distance"] - 40, 10)
        else:
            dist = 50
        print(f"[DRIVE] {dist:.0f}mm to ball")
        self.post_data(dist)


class AskGPTStrategy(StateNode):
    """
    Near the ball now. Ask GPT: should I kick straight, or go around?
    Uses AskGPT node pattern > builds query, lets parent FSM handle the call.
    
    Posts:
      "kick_straight" > just aim-adjust and kick
      "go_around_left" > circle around left, then kick
      "go_around_right" > circle around right, then kick
    """
    def start(self, event=None):
        super().start(event)
        mem = self.parent.field_memory

        # No goal known? Just kick straight, can't plan without goal
        if mem.goal_center is None:
            print("[GPT] No goal in memory - kicking straight")
            self.parent.gpt_plan = "kick_straight"
            self.parent.gpt_aim_adjust = 0
            self.post_data("kick_straight")
            return

        rx = getattr(robot, "x", 0)
        ry = getattr(robot, "y", 0)
        rh = getattr(robot, "heading", 0)
        snapshot = mem.snapshot_for_ai(rx, ry, rh)

        query = (f"I'm near the ball. Here's the field state:\n{snapshot}\n"
                 f"What should I do to score? Reply JSON only.")

        print("[GPT] Asking for strategy...")
        try:
            robot.openai_client.set_preamble(STRATEGY_PREAMBLE)
            response = robot.openai_client.chat(query)
            result = self._parse(response)
            
            plan = result.get("plan", "kick_straight")
            aim = result.get("aim_adjust_degrees", 0)
            aim = max(-60, min(60, aim))
            reason = result.get("reasoning", "")
            
            print(f"[GPT] Plan: {plan} | Aim adjust: {aim}degrees | {reason}")
            
            self.parent.gpt_plan = plan
            self.parent.gpt_aim_adjust = aim
            self.post_data(plan)
            
        except Exception as e:
            print(f"[GPT] Failed ({e}), using geometry fallback")
            plan, aim = self._geometry_fallback(mem)
            self.parent.gpt_plan = plan
            self.parent.gpt_aim_adjust = aim
            self.post_data(plan)

    def _geometry_fallback(self, mem):
        """Pure math fallback when GPT is unavailable."""
        target = self.parent.target_ball
        if not target or not mem.goal_center:
            return "kick_straight", 0

        bx, by = target.get("x"), target.get("y")
        gx, gy = mem.goal_center
        if bx is None or by is None:
            return "kick_straight", 0

        rx = getattr(robot, "x", 0)
        ry = getattr(robot, "y", 0)
        rh = getattr(robot, "heading", 0)

        # Angle from ball to goal
        ball_to_goal = math.degrees(math.atan2(gy - by, gx - bx))
        # Angle from robot to ball
        robot_to_ball = math.degrees(math.atan2(by - ry, bx - rx))
        
        # Check if robot is roughly on the opposite side of ball from goal
        # (i.e. robot > ball > goal is roughly a line)
        diff = abs(robot_to_ball - ball_to_goal)
        if diff > 180: diff = 360 - diff
        
        if diff < 50:
            # Good position - robot behind ball relative to goal
            # Calculate aim adjustment
            angle_to_goal = math.degrees(math.atan2(gy - ry, gx - rx))
            aim = angle_to_goal - rh
            while aim > 180:  aim -= 360
            while aim < -180: aim += 360
            aim = max(-60, min(60, aim))
            print(f"[FALLBACK] Good position, kick_straight, aim {aim:.1f} degrees")
            return "kick_straight", aim
        else:
            # Bad position - need to go around
            # Figure out which side: cross product of robot>ball and ball>goal
            rbx, rby = bx - rx, by - ry
            bgx, bgy = gx - bx, gy - by
            cross = rbx * bgy - rby * bgx
            side = "go_around_left" if cross > 0 else "go_around_right"
            print(f"[FALLBACK] Wrong side, need to {side}")
            return side, 0

    def _parse(self, text):
        text = text.strip()
        if text.startswith("```"):
            text = text.split("\n", 1)[1].rsplit("```", 1)[0]
        return json.loads(text)


class DoAimAdjust(StateNode):
    """Apply GPT's aim adjustment before kicking."""
    def start(self, event=None):
        super().start(event)
        turn = self.parent.gpt_aim_adjust
        if abs(turn) < 2:
            print("[AIM] Aligned, kicking!")
            self.post_completion()
        else:
            print(f"[AIM] Adjusting {turn:.1f} degrees")
            self.post_data(turn)


class GoAroundBall(StateNode):
    """
    Execute a go-around maneuver: sidestep + arc around the ball
    so the robot ends up on the opposite side from the goal.
    """
    def start(self, event=None):
        super().start(event)
        plan = self.parent.gpt_plan
        mem = self.parent.field_memory
        target = self.parent.target_ball

        if not target or not mem.goal_center:
            self.post_completion()
            return

        bx, by = target.get("x"), target.get("y")
        gx, gy = mem.goal_center
        if bx is None or by is None:
            self.post_completion()
            return

        rx = getattr(robot, "x", 0)
        ry = getattr(robot, "y", 0)
        rh = getattr(robot, "heading", 0)

        # We want to end up on the far side of the ball from the goal
        # Angle from goal to ball (the "behind" direction)
        behind_angle = math.degrees(math.atan2(by - gy, bx - gx))
        
        # Target position: 130mm behind the ball (away from goal)
        offset = 130
        target_x = bx + offset * math.cos(math.radians(behind_angle))
        target_y = by + offset * math.sin(math.radians(behind_angle))

        # First: turn to face the target position
        angle_to_target = math.degrees(math.atan2(target_y - ry, target_x - rx))
        turn = angle_to_target - rh
        while turn > 180:  turn -= 360
        while turn < -180: turn += 360

        dist = math.sqrt((target_x - rx)**2 + (target_y - ry)**2)
        dist = min(dist, 350)
        dist = max(dist, 50)

        self.parent.around_turn = turn
        self.parent.around_drive = dist

        # After arriving behind the ball, we need to face the goal
        face_goal_angle = math.degrees(math.atan2(gy - target_y, gx - target_x))
        # This is the heading we want after arriving, relative to what our heading will be
        # After driving, our heading will be approximately angle_to_target
        self.parent.face_goal_turn = face_goal_angle - angle_to_target
        while self.parent.face_goal_turn > 180:  self.parent.face_goal_turn -= 360
        while self.parent.face_goal_turn < -180: self.parent.face_goal_turn += 360

        direction = "LEFT" if plan == "go_around_left" else "RIGHT"
        print(f"[AROUND] Going {direction}: turn {turn:.1f} degrees, drive {dist:.0f}mm, "
              f"then face goal {self.parent.face_goal_turn:.1f} degrees")
        self.post_data(turn)


class GetAroundDrive(StateNode):
    """Post the drive distance for the go-around maneuver."""
    def start(self, event=None):
        super().start(event)
        dist = getattr(self.parent, "around_drive", 100)
        print(f"[AROUND] Driving {dist:.0f}mm behind ball")
        self.post_data(dist)


class FaceGoalTurn(StateNode):
    """After going around, turn to face the goal through the ball."""
    def start(self, event=None):
        super().start(event)
        turn = getattr(self.parent, "face_goal_turn", 0)
        if abs(turn) < 2:
            print("[AROUND] Already facing goal")
            self.post_completion()
        else:
            print(f"[AROUND] Facing goal: {turn:.1f} degrees")
            self.post_data(turn)


class smart_kick(StateMachineProgram):
    """
    v5 - GPT-guided scoring.

    1. SLAM runs constantly, remembers goal posts (2min) and balls (30s).
    2. See ball > charge toward it.
    3. Stop near ball > ask GPT: "kick straight or go around?"
    4. GPT says kick_straight > small aim adjust > kick
       GPT says go_around_left/right > drive behind ball > face goal > kick
    5. Loop.
    """

    def __init__(self):
        super().__init__(
            launch_cam_viewer=True,
            launch_worldmap_viewer=True,
        )
        self.field_memory = FieldMemory(stale_timeout=30.0)
        self.target_ball = None
        self.gpt_plan = "kick_straight"
        self.gpt_aim_adjust = 0
        self.around_turn = 0
        self.around_drive = 100
        self.face_goal_turn = 0

    $setup{
        Glow(vex.LightType.ALL_LEDS, 0, 0, 255) =C=> loop
        loop: UpdateMemory()
        loop =C=> team_lights
        
        team_lights: team_lights()
        team_lights =C=> find_goal

        find_goal:goal_detection()
        find_goal =F=> scan
        find_goal =S=> find_ball

        find_ball: FindClosestBall()
        find_ball =D=> charge
        find_ball =S=> go_remembered
        find_ball =F=> scan

        # --- No ball: turn + pause ---
        scan: Turn(45)
        scan =T(1.5)=> scan_pause
        scan_pause: StateNode()
        scan_pause =T(0.5)=> loop

        # --- Remembered ball: go to last known position ---
        go_remembered: GoToRememberedBall()
        go_remembered =D=> Turn() =C=> Forward(150) =C=> loop

        # --- Ball visible: charge toward it ---
        charge: TurnToward()
        charge =C=> get_dist

        get_dist: GetBallDistance()
        get_dist =D=> Forward() =C=> near_ball

        near_ball: UpdateMemory()
        near_ball =C=> ask_gpt

        ask_gpt: AskGPTStrategy()
        ask_gpt =D('kick_straight')=> aim_adjust
        ask_gpt =D('go_around_left')=> go_around
        ask_gpt =D('go_around_right')=> go_around
        ask_gpt =D=> aim_adjust

        aim_adjust: DoAimAdjust()
        aim_adjust =D=> Turn() =C=> do_kick
        aim_adjust =C=> do_kick

        go_around: GoAroundBall()
        go_around =D=> Turn() =C=> drive_around
        go_around =C=> do_kick
        drive_around: GetAroundDrive()
        drive_around =D=> Forward() =C=> face_goal

        face_goal: FaceGoalTurn()
        face_goal =D=> Turn() =C=> charge_goal
        face_goal =C=> charge_goal
        # After going around, drive forward into the ball and kick
        charge_goal: Forward(120)
        charge_goal =C=> do_kick
        do_kick: Kick()
        do_kick =C=> CheckGoal
        CheckGoal: CheckGoal()
        CheckGoal =F=> loop
        CheckGoal =S=> loop
    }